# =================================================================
# AI Document Extraction Project — Environment Variables Template
# =================================================================
# 複製此檔案為 .env 並填入實際值：  cp .env.example .env
#
# 分級標記：
#   🔴 必要    缺少則無法啟動
#   🟡 功能    缺少則特定功能不可用
#   🟢 可選    缺少不影響基本運行
#
# 變更歷史：
#   CHANGE-054 (2026-04-22): 補齊 15 個先前缺失變數 + port 5432→5433
#   FIX-054    (2026-04-22): 新增 SYSTEM_USER_ID
# =================================================================


# =================================================================
# 🔴 必要變數（缺少則無法啟動）
# =================================================================

# ---- Database ----
# docker-compose 將 PostgreSQL 對外映射到 5433（容器內是 5432）
# ⚠️ 務必使用 5433，否則會連線失敗
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/ai_document_extraction?schema=public"

# ---- NextAuth (Auth.js v5) ----
# 生成密鑰：npx auth secret
AUTH_SECRET="your-nextauth-secret-key-change-in-production"
AUTH_URL="http://localhost:3005"
# 非 HTTPS 環境（本地開發、internal）必須設為 "true"，否則 JWT decrypt 失敗
AUTH_TRUST_HOST="true"

# ---- JWT / Session ----
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-jwt-secret-32-char-hex-change-in-production"
JWT_EXPIRES_IN="7d"
SESSION_SECRET="your-session-secret-32-char-hex-change-in-production"

# ---- Encryption ----
# 用於敏感資料加密（API keys、整合憑證等）
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ⚠️ 一旦設定後不可變更，否則既有加密資料無法解密
ENCRYPTION_KEY="your-encryption-key-32-char-hex-change-in-production"

# ---- System User (FIX-054) ----
# 用於 server-side 操作的系統用戶 ID（company auto-create、batch processing、
# SharePoint/Outlook 文件抓取、Issuer Identification 預設值）。
#
# 全新環境：保持 "system-user-1"（由 prisma/seed.ts 建立的固定 ID）
# 既有環境：若資料庫中 system user 已有不同 UUID，設為該 UUID 可避免資料遷移
#   查詢方式：SELECT id FROM users WHERE email = 'system@ai-document-extraction.internal';
SYSTEM_USER_ID="system-user-1"

# ---- Application ----
NEXT_PUBLIC_APP_URL="http://localhost:3005"
NODE_ENV="development"


# =================================================================
# 🟡 功能相關變數（缺少則對應功能不可用）
# =================================================================

# ---- Azure AD (Entra ID) SSO ----
# 缺少時：系統進入 dev mode，接受任何含 @ 的 email 登入
# Get these values from Azure Portal > App Registrations
AZURE_AD_CLIENT_ID="your-azure-ad-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-ad-client-secret"
AZURE_AD_TENANT_ID="your-azure-ad-tenant-id"

# ---- Azure Blob Storage ----
# 缺少時：文件上傳功能不可用
# ===================================================================
# 生產環境: 使用 Azure 真實連接字符串
# AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net"
#
# 開發環境 (Azurite): 使用以下連接字符串
# 先執行: docker-compose up -d azurite
# 這是 Azurite 的標準開發帳戶，可安全使用於開發環境
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNOcqFlqUwJPLlmEtlCDXJ1OUzFT50uSRZ6IFsuFq2UVErCz4I6tq/K1SZFPTOtr/KBHBeksoGMGw==;BlobEndpoint=http://127.0.0.1:10010/devstoreaccount1;"
# ===================================================================
AZURE_STORAGE_CONTAINER="documents"

# ---- Azure Document Intelligence (for Python OCR Service) ----
# 缺少時：OCR 文字識別不可用
AZURE_DI_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"
AZURE_DI_KEY="your-api-key"

# ---- Python Microservices ----
# 由 docker-compose 提供，預設值通常不用改
OCR_SERVICE_URL="http://localhost:8000"
MAPPING_SERVICE_URL="http://localhost:8001"

# ---- Azure OpenAI GPT-5.2 Configuration ----
# Used for: Vision OCR, Term Classification, AI Processing
# Pricing: Input $1.750/1M tokens, Output $14.000/1M tokens
# 缺少時：AI 欄位提取、智能分類、Vision OCR 都不可用
AZURE_OPENAI_API_KEY="your-azure-openai-subscription-key"
AZURE_OPENAI_ENDPOINT="https://your-resource.cognitiveservices.azure.com/"
AZURE_OPENAI_DEPLOYMENT_NAME="gpt-5.2"
AZURE_OPENAI_API_VERSION="2025-03-01-preview"

# ---- Azure OpenAI 多模型路由（可選，用於成本優化） ----
# 若未設定，系統會統一使用 AZURE_OPENAI_DEPLOYMENT_NAME
AZURE_OPENAI_MINI_DEPLOYMENT_NAME="gpt-5.2-mini"
AZURE_OPENAI_NANO_DEPLOYMENT_NAME="gpt-5.2-nano"

# ---- Optional: Azure AD Tenant ID ----
# 使用 token-based auth 代替 API key 時設定
# AZURE_OPENAI_TENANT_ID="your-tenant-id"

# ---- V3 Extraction Pipeline Feature Flags (Epic 15) ----
# FEATURE_EXTRACTION_V3: 啟用 V3 三階段提取管線
# FEATURE_EXTRACTION_V3_1: 啟用 V3.1 升級（新公司智能降級）
# _FALLBACK: 若 V3.1 失敗是否降回 V3
# _PERCENTAGE: 逐步上線控制（0-100，0=停用，100=全量）
FEATURE_EXTRACTION_V3="true"
FEATURE_EXTRACTION_V3_1="true"
FEATURE_EXTRACTION_V3_1_FALLBACK="true"
FEATURE_EXTRACTION_V3_PERCENTAGE="100"
FEATURE_EXTRACTION_V3_1_PERCENTAGE="100"

# ---- Unified Document Processor (Epic 15) ----
# "true" 啟用 11-step unified pipeline；"false" 使用舊版 OCR-only 流程
ENABLE_UNIFIED_PROCESSOR="false"


# =================================================================
# 🟢 可選變數（缺少不影響基本運行）
# =================================================================

# ---- Upstash Redis (Rate Limiting & Caching) ----
# 缺少時：Rate limit 退回 in-memory Map（僅單實例有效）
# Get these values from https://console.upstash.com/
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ---- n8n Workflow Engine Integration ----
# 缺少時：工作流自動化、webhook 觸發不可用
N8N_BASE_URL="http://localhost:5678"
N8N_API_KEY=""

# ---- Microsoft Graph API (SharePoint / Outlook Integration) ----
# 缺少時：SharePoint 文件抓取、Outlook 郵件監控不可用
# Get these values from Azure Portal > App Registrations
MICROSOFT_GRAPH_CLIENT_ID=""
MICROSOFT_GRAPH_CLIENT_SECRET=""
MICROSOFT_GRAPH_TENANT_ID=""

# ---- Password Hashing Configuration ----
# bcrypt salt rounds（預設 12，範圍 10-14）
# 數值越高越安全但 hashing 越慢
BCRYPT_SALT_ROUNDS="12"

# ---- Debug Flags ----
# "true" 會在 log 中輸出 V3 extraction 的 Prompt 和 Response（含完整內容）
# ⚠️ 僅開發除錯用，生產環境務必關閉（會洩漏敏感資料到日誌）
DEBUG_EXTRACTION_V3_PROMPT="false"
DEBUG_EXTRACTION_V3_RESPONSE="false"
