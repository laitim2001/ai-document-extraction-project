generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String                    @id @default(cuid())
  email                      String                    @unique
  emailVerified              DateTime?                 @map("email_verified")
  name                       String?
  image                      String?
  password                   String?
  azureAdId                  String?                   @unique @map("azure_ad_id")
  status                     UserStatus                @default(ACTIVE)
  createdAt                  DateTime                  @default(now()) @map("created_at")
  updatedAt                  DateTime                  @updatedAt @map("updated_at")
  lastLoginAt                DateTime?                 @map("last_login_at")
  isGlobalAdmin              Boolean                   @default(false) @map("is_global_admin")
  isRegionalManager          Boolean                   @default(false) @map("is_regional_manager")
  emailVerificationExpires   DateTime?                 @map("email_verification_expires")
  emailVerificationToken     String?                   @unique @map("email_verification_token")
  lastActiveAt               DateTime?                 @map("last_active_at")
  passwordResetExpires       DateTime?                 @map("password_reset_expires")
  passwordResetToken         String?                   @unique @map("password_reset_token")
  preferredLocale            String?                   @default("en") @map("preferred_locale")
  accounts                   Account[]
  alertRulesCreated          AlertRule[]               @relation("AlertRuleCreator")
  apiKeys                    ApiKey[]                  @relation("ApiKeyCreator")
  auditLogs                  AuditLog[]
  auditReportDownloads       AuditReportDownload[]     @relation("AuditReportDownloader")
  auditReportJobs            AuditReportJob[]          @relation("AuditReportJobRequester")
  backupSchedulesCreated     BackupSchedule[]          @relation("BackupScheduleCreator")
  backupsCreated             Backup[]                  @relation("BackupCreator")
  companiesCreated           Company[]                 @relation("CompanyCreator")
  configChanges              ConfigHistory[]           @relation("ConfigChanger")
  corrections                Correction[]
  dataChangeHistories        DataChangeHistory[]       @relation("DataChangeHistoryCreator")
  deletionRequestsApproved   DataDeletionRequest[]     @relation("DeletionRequestApprover")
  deletionRequestsCreated    DataDeletionRequest[]     @relation("DeletionRequestRequester")
  restoreRequests            DataRestoreRequest[]      @relation("RestoreRequestRequester")
  retentionPolicies          DataRetentionPolicy[]     @relation("RetentionPolicyCreator")
  documents                  Document[]
  escalationsAssigned        Escalation[]              @relation("EscalationAssignee")
  escalationsCreated         Escalation[]              @relation("EscalationEscalator")
  escalationsResolved        Escalation[]              @relation("EscalationResolver")
  externalApiKeys            ExternalApiKey[]          @relation("ExternalApiKeyCreator")
  forwarderAssignments       ForwarderIdentification[]
  forwardersCreated          Forwarder[]               @relation("ForwarderCreator")
  historicalBatchesCreated   HistoricalBatch[]         @relation("HistoricalBatchCreator")
  logExports                 LogExport[]               @relation("LogExportCreator")
  createdRules               MappingRule[]             @relation("RuleCreator")
  monthlyReports             MonthlyReport[]           @relation("MonthlyReportGenerator")
  n8nApiKeys                 N8nApiKey[]               @relation("N8nApiKeyCreator")
  notifications              Notification[]
  outlookConfigs             OutlookConfig[]           @relation("OutlookConfigCreator")
  outlookConfigsUpdated      OutlookConfig[]           @relation("OutlookConfigUpdater")
  assignedQueues             ProcessingQueue[]
  reportJobs                 ReportJob[]               @relation("UserReportJobs")
  restoreRecordsCreated      RestoreRecord[]           @relation("RestoreRecordCreator")
  reviewRecords              ReviewRecord[]
  verifiedApplications       RuleApplication[]         @relation("ApplicationVerifier")
  changeRequestsCreated      RuleChangeRequest[]       @relation("ChangeRequester")
  changeRequestsReviewed     RuleChangeRequest[]       @relation("ChangeReviewer")
  reviewedSuggestions        RuleSuggestion[]          @relation("RuleSuggestionReviewer")
  suggestedRules             RuleSuggestion[]          @relation("RuleSuggestionSuggester")
  testTasksCreated           RuleTestTask[]            @relation("TestTaskCreator")
  createdVersions            RuleVersion[]             @relation("VersionCreator")
  resolvedSecurityLogs       SecurityLog[]             @relation("SecurityLogResolver")
  securityLogs               SecurityLog[]             @relation("SecurityLogUser")
  sessions                   Session[]
  sharePointConfigs          SharePointConfig[]        @relation("SharePointConfigCreator")
  sharePointConfigsUpdated   SharePointConfig[]        @relation("SharePointConfigUpdater")
  configsUpdated             SystemConfig[]            @relation("ConfigUpdater")
  systemLogs                 SystemLog[]               @relation("SystemLogUser")
  traceabilityReports        TraceabilityReport[]      @relation("TraceabilityReportGenerator")
  grantedCityAccesses        UserCityAccess[]          @relation("GrantedCityAccess")
  cityAccesses               UserCityAccess[]          @relation("UserCityAccess")
  grantedRegionAccesses      UserRegionAccess[]        @relation("GrantedRegionAccess")
  regionAccesses             UserRegionAccess[]        @relation("UserRegionAccess")
  roles                      UserRole[]
  webhookConfigHistories     WebhookConfigHistory[]    @relation("WebhookConfigHistoryCreator")
  webhookConfigsCreated      WebhookConfig[]           @relation("WebhookConfigCreator")
  webhookConfigsUpdated      WebhookConfig[]           @relation("WebhookConfigUpdater")
  workflowDefinitionsCreated WorkflowDefinition[]      @relation("WorkflowDefinitionCreator")
  workflowDefinitionsUpdated WorkflowDefinition[]      @relation("WorkflowDefinitionUpdater")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  userAgent    String?  @map("user_agent")
  ipAddress    String?  @map("ip_address")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Role {
  id          String     @id @default(cuid())
  name        String     @unique
  description String?
  permissions String[]
  isSystem    Boolean    @default(false) @map("is_system")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  users       UserRole[]

  @@map("roles")
}

model UserRole {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  roleId    String   @map("role_id")
  cityId    String?  @map("city_id")
  createdAt DateTime @default(now()) @map("created_at")
  city      City?    @relation(fields: [cityId], references: [id])
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@index([cityId])
  @@map("user_roles")
}

/**
 * 地區配置表
 * 用於分類管理城市和 Reference Number
 * @since Epic 6 - Story 6.1, Epic 20 - Story 20.1
 */
model Region {
  id           String             @id @default(uuid())
  code         String             @unique
  name         String
  description  String?                                           // Epic 20: 地區說明
  parentId     String?            @map("parent_id")
  timezone     String             @default("UTC")
  status       RegionStatus       @default(ACTIVE)
  isDefault    Boolean            @default(false) @map("is_default")  // Epic 20: 是否為系統預設
  sortOrder    Int                @default(0) @map("sort_order")      // Epic 20: 排序順序
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")

  // 關聯
  cities            City[]
  parent            Region?            @relation("RegionHierarchy", fields: [parentId], references: [id])
  children          Region[]           @relation("RegionHierarchy")
  userAccesses      UserRegionAccess[]
  referenceNumbers  ReferenceNumber[]  // Epic 20: 參考號碼關聯
  pipelineConfigs   PipelineConfig[]   // CHANGE-032: Pipeline 配置關聯

  @@index([parentId])
  @@index([status])
  @@index([isDefault])
  @@index([sortOrder])
  @@map("regions")
}

model City {
  id                   String                 @id @default(uuid())
  code                 String                 @unique
  name                 String
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  regionId             String                 @map("region_id")
  timezone             String                 @default("UTC")
  currency             String                 @default("USD")
  locale               String                 @default("en-US")
  status               CityStatus             @default(ACTIVE)
  config               Json?
  alertRules           AlertRule[]
  alerts               Alert[]
  auditLogs            AuditLog[]             @relation("AuditLogCity")
  region               Region                 @relation(fields: [regionId], references: [id])
  documents            Document[]             @relation("DocumentCity")
  externalApiTasks     ExternalApiTask[]
  n8nApiKeys           N8nApiKey[]
  n8nConnectionStats   N8nConnectionStats[]
  outlookConfig        OutlookConfig?
  outlookFetchLogs     OutlookFetchLog[]
  processingStatistics ProcessingStatistics[]
  sharePointConfig     SharePointConfig?
  sharePointFetchLogs  SharePointFetchLog[]
  systemConfigs        SystemConfig[]         @relation("ConfigCity")
  systemHealthLogs     SystemHealthLog[]
  userAccesses         UserCityAccess[]
  userRoles            UserRole[]
  webhookConfigs       WebhookConfig[]
  workflowDefinitions  WorkflowDefinition[]
  workflowExecutions   WorkflowExecution[]

  @@index([regionId])
  @@index([status])
  @@index([code])
  @@map("cities")
}

model UserCityAccess {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  cityId      String      @map("city_id")
  isPrimary   Boolean     @default(false) @map("is_primary")
  grantedBy   String      @map("granted_by")
  grantedAt   DateTime    @default(now()) @map("granted_at")
  expiresAt   DateTime?   @map("expires_at")
  reason      String?
  accessLevel AccessLevel @default(FULL)
  city        City        @relation(fields: [cityId], references: [id])
  grantor     User        @relation("GrantedCityAccess", fields: [grantedBy], references: [id])
  user        User        @relation("UserCityAccess", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, cityId])
  @@index([userId])
  @@index([cityId])
  @@index([expiresAt])
  @@map("user_city_access")
}

model UserRegionAccess {
  id          String      @id @default(uuid())
  userId      String      @map("user_id")
  regionId    String      @map("region_id")
  accessLevel AccessLevel @default(FULL)
  grantedBy   String      @map("granted_by")
  grantedAt   DateTime    @default(now()) @map("granted_at")
  expiresAt   DateTime?   @map("expires_at")
  reason      String?
  grantor     User        @relation("GrantedRegionAccess", fields: [grantedBy], references: [id])
  region      Region      @relation(fields: [regionId], references: [id])
  user        User        @relation("UserRegionAccess", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, regionId])
  @@index([userId])
  @@index([regionId])
  @@index([expiresAt])
  @@map("user_region_access")
}

model AuditLog {
  id           String      @id @default(uuid())
  userId       String      @map("user_id")
  ipAddress    String?     @map("ip_address")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  cityCode     String?     @map("city_code")
  changes      Json?
  description  String?
  errorMessage String?     @map("error_message")
  isArchived   Boolean     @default(false) @map("is_archived")
  metadata     Json?
  requestId    String?     @map("request_id")
  resourceId   String?     @map("resource_id")
  resourceName String?     @map("resource_name")
  resourceType String      @map("resource_type")
  sessionId    String?     @map("session_id")
  status       AuditStatus @default(SUCCESS)
  userAgent    String?     @map("user_agent")
  userEmail    String?     @map("user_email")
  userName     String      @map("user_name")
  action       AuditAction
  city         City?       @relation("AuditLogCity", fields: [cityCode], references: [code])
  user         User        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@index([cityCode, createdAt])
  @@index([status])
  @@map("audit_logs")
}

model Document {
  id                  String                    @id @default(uuid())
  fileName            String                    @map("file_name")
  fileType            String                    @map("file_type")
  fileExtension       String                    @map("file_extension")
  fileSize            Int                       @map("file_size")
  filePath            String                    @map("file_path")
  blobName            String                    @map("blob_name")
  status              DocumentStatus            @default(UPLOADED)
  errorMessage        String?                   @map("error_message")
  processingPath      ProcessingPath?           @map("processing_path")
  routingDecision     Json?                     @map("routing_decision")
  uploadedBy          String                    @map("uploaded_by")
  cityCode            String                    @map("city_code")
  createdAt           DateTime                  @default(now()) @map("created_at")
  updatedAt           DateTime                  @updatedAt @map("updated_at")
  forwarderId         String?                   @map("forwarder_id")
  companyId           String?                   @map("company_id")
  fileHash            String?                   @map("file_hash")
  processingDuration  Int?                      @map("processing_duration")
  processingEndedAt   DateTime?                 @map("processing_ended_at")
  processingStartedAt DateTime?                 @map("processing_started_at")
  sharepointDriveId   String?                   @map("sharepoint_drive_id")
  sharepointItemId    String?                   @map("sharepoint_item_id")
  sharepointSiteId    String?                   @map("sharepoint_site_id")
  sharepointUrl       String?                   @map("sharepoint_url")
  sourceMetadata      Json?                     @map("source_metadata")
  sourceType          DocumentSourceType        @default(MANUAL_UPLOAD) @map("source_type")
  workflowExecutionId String?                   @map("workflow_execution_id")
  templateInstanceId  String?                   @map("template_instance_id")
  templateMatchedAt   DateTime?                 @map("template_matched_at")
  apiUsageLogs        ApiUsageLog[]             @relation("DocumentApiUsageLogs")
  corrections         Correction[]
  processingStages    DocumentProcessingStage[]
  city                City                      @relation("DocumentCity", fields: [cityCode], references: [code])
  company             Company?                  @relation("CompanyDocuments", fields: [companyId], references: [id])
  forwarder           Forwarder?                @relation(fields: [forwarderId], references: [id])
  templateInstance    TemplateInstance?         @relation("TemplateInstanceDocuments", fields: [templateInstanceId], references: [id])
  uploader            User                      @relation(fields: [uploadedBy], references: [id])
  workflowExecution   WorkflowExecution?        @relation("WorkflowExecutionDocuments", fields: [workflowExecutionId], references: [id])
  escalation          Escalation?
  externalApiTask     ExternalApiTask?
  extractionResult    ExtractionResult?
  identifications     ForwarderIdentification?
  n8nWebhookEvents    N8nWebhookEvent[]
  ocrResult           OcrResult?
  processingQueue     ProcessingQueue?
  reviewRecords       ReviewRecord[]
  ruleApplications    RuleApplication[]
  testDetails         RuleTestDetail[]
  sharePointFetchLogs SharePointFetchLog[]
  suggestionSamples   SuggestionSample[]
  traceabilityReports TraceabilityReport[]

  @@index([status])
  @@index([uploadedBy])
  @@index([cityCode])
  @@index([forwarderId])
  @@index([companyId])
  @@index([createdAt])
  @@index([sourceType])
  @@index([sharepointItemId])
  @@index([workflowExecutionId])
  @@index([templateInstanceId])
  @@map("documents")
}

model OcrResult {
  id             String   @id @default(uuid())
  documentId     String   @unique @map("document_id")
  rawResult      Json     @map("raw_result")
  extractedText  String   @map("extracted_text")
  invoiceData    Json?    @map("invoice_data")
  processingTime Int?     @map("processing_time")
  pageCount      Int?     @map("page_count")
  confidence     Float?   @map("confidence")
  errorCode      String?  @map("error_code")
  errorMessage   String?  @map("error_message")
  retryCount     Int      @default(0) @map("retry_count")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("ocr_results")
}

model Forwarder {
  id                     String                    @id @default(uuid())
  name                   String                    @unique
  code                   String                    @unique
  displayName            String                    @map("display_name")
  identificationPatterns Json                      @map("identification_patterns")
  isActive               Boolean                   @default(true) @map("is_active")
  priority               Int                       @default(0)
  createdAt              DateTime                  @default(now()) @map("created_at")
  updatedAt              DateTime                  @updatedAt @map("updated_at")
  contactEmail           String?                   @map("contact_email")
  createdById            String?                   @map("created_by_id")
  defaultConfidence      Float                     @default(0.8) @map("default_confidence")
  description            String?
  logoUrl                String?                   @map("logo_url")
  status                 ForwarderStatus           @default(PENDING)
  correctionPatterns     CorrectionPattern[]
  documents              Document[]
  extractionResults      ExtractionResult[]
  fieldCorrectionHistory FieldCorrectionHistory[]
  identifications        ForwarderIdentification[]
  createdBy              User?                     @relation("ForwarderCreator", fields: [createdById], references: [id])
  mappingRules           MappingRule[]
  changeRequests         RuleChangeRequest[]
  ruleSuggestions        RuleSuggestion[]
  testTasks              RuleTestTask[]

  @@index([code])
  @@index([isActive])
  @@index([status])
  @@index([createdById])
  @@map("forwarders")
}

model ForwarderIdentification {
  id               String               @id @default(uuid())
  documentId       String               @unique @map("document_id")
  forwarderId      String?              @map("forwarder_id")
  confidence       Float
  matchMethod      String               @map("match_method")
  matchedPatterns  String[]             @map("matched_patterns")
  matchDetails     Json?                @map("match_details")
  isAutoMatched    Boolean              @default(true) @map("is_auto_matched")
  isManual         Boolean              @default(false) @map("is_manual")
  manualAssignedBy String?              @map("manual_assigned_by")
  manualAssignedAt DateTime?            @map("manual_assigned_at")
  status           IdentificationStatus @default(PENDING)
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  document         Document             @relation(fields: [documentId], references: [id], onDelete: Cascade)
  forwarder        Forwarder?           @relation(fields: [forwarderId], references: [id])
  assignedBy       User?                @relation(fields: [manualAssignedBy], references: [id])

  @@index([documentId])
  @@index([forwarderId])
  @@index([status])
  @@index([confidence])
  @@map("forwarder_identifications")
}

model Company {
  id                        String                   @id @default(uuid())
  name                      String
  code                      String?                  @unique
  displayName               String                   @map("display_name")
  type                      CompanyType              @default(UNKNOWN)
  status                    CompanyStatus            @default(PENDING)
  source                    CompanySource            @default(MANUAL)
  nameVariants              String[]                 @map("name_variants")
  identificationPatterns    String[]                 @map("identification_patterns")
  mergedIntoId              String?                  @map("merged_into_id")
  firstSeenDocumentId       String?                  @map("first_seen_document_id")
  logoUrl                   String?                  @map("logo_url")
  contactEmail              String?                  @map("contact_email")
  description               String?
  priority                  Int                      @default(0)
  defaultConfidence         Float                    @default(0.8) @map("default_confidence")
  createdById               String                   @map("created_by_id")
  createdAt                 DateTime                 @default(now()) @map("created_at")
  updatedAt                 DateTime                 @updatedAt @map("updated_at")
  defaultTemplateId         String?                  @map("default_template_id")
  creator                   User                     @relation("CompanyCreator", fields: [createdById], references: [id])
  defaultTemplate           DataTemplate?            @relation("CompanyDefaultTemplate", fields: [defaultTemplateId], references: [id])
  mergedInto                Company?                 @relation("CompanyMerge", fields: [mergedIntoId], references: [id])
  mergedFrom                Company[]                @relation("CompanyMerge")
  correctionPatterns        CorrectionPattern[]      @relation("CompanyCorrectionPatterns")
  dataTemplates             DataTemplate[]
  documentFormats           DocumentFormat[]
  documents                 Document[]               @relation("CompanyDocuments")
  extractionResults         ExtractionResult[]       @relation("CompanyExtractionResults")
  correctionHistories       FieldCorrectionHistory[]
  fieldMappingConfigs       FieldMappingConfig[]
  transactionParticipations FileTransactionParty[]
  issuedDocuments           HistoricalFile[]         @relation("FileDocumentIssuer")
  identifiedHistoricalFiles HistoricalFile[]         @relation("FileIdentifiedCompany")
  mappingRules              MappingRule[]            @relation("CompanyMappingRules")
  promptConfigs             PromptConfig[]
  changeRequests            RuleChangeRequest[]
  ruleSuggestions           RuleSuggestion[]         @relation("CompanyRuleSuggestions")
  testTasks                 RuleTestTask[]           @relation("CompanyTestTasks")
  templateFieldMappings     TemplateFieldMapping[]
  pipelineConfigs           PipelineConfig[]           // CHANGE-032: Pipeline 配置關聯

  @@index([type])
  @@index([status])
  @@index([name])
  @@index([source])
  @@index([createdById])
  @@index([mergedIntoId])
  @@map("companies")
}

model MappingRule {
  id                String              @id @default(uuid())
  forwarderId       String?             @map("forwarder_id")
  fieldName         String              @map("field_name")
  fieldLabel        String              @map("field_label")
  extractionPattern Json                @map("extraction_pattern")
  priority          Int                 @default(0)
  isRequired        Boolean             @default(false) @map("is_required")
  isActive          Boolean             @default(true) @map("is_active")
  validationPattern String?             @map("validation_pattern")
  defaultValue      String?             @map("default_value")
  category          String?
  description       String?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")
  companyId         String?             @map("company_id")
  confidence        Float               @default(0.8)
  createdBy         String?             @map("created_by")
  status            RuleStatus          @default(ACTIVE)
  suggestionId      String?             @unique @map("suggestion_id")
  version           Int                 @default(1)
  company           Company?            @relation("CompanyMappingRules", fields: [companyId], references: [id])
  creator           User?               @relation("RuleCreator", fields: [createdBy], references: [id])
  forwarder         Forwarder?          @relation(fields: [forwarderId], references: [id])
  suggestion        RuleSuggestion?     @relation("CreatedFromSuggestion", fields: [suggestionId], references: [id])
  rollbackLogs      RollbackLog[]
  applications      RuleApplication[]
  changeRequests    RuleChangeRequest[]
  testTasks         RuleTestTask[]
  versions          RuleVersion[]

  @@unique([forwarderId, fieldName])
  @@index([forwarderId])
  @@index([companyId])
  @@index([fieldName])
  @@index([category])
  @@index([isActive])
  @@index([status])
  @@index([createdBy])
  @@map("mapping_rules")
}

model ExtractionResult {
  id                   String           @id @default(uuid())
  documentId           String           @unique @map("document_id")
  forwarderId          String?          @map("forwarder_id")
  fieldMappings        Json             @map("field_mappings")
  totalFields          Int              @map("total_fields")
  mappedFields         Int              @map("mapped_fields")
  unmappedFields       Int              @map("unmapped_fields")
  averageConfidence    Float            @map("average_confidence")
  processingTime       Int?             @map("processing_time")
  rulesApplied         Int              @map("rules_applied")
  status               ExtractionStatus @default(PENDING)
  errorMessage         String?          @map("error_message")
  unmappedFieldDetails Json?            @map("unmapped_field_details")
  createdAt            DateTime         @default(now()) @map("created_at")
  updatedAt            DateTime         @updatedAt @map("updated_at")
  confidenceScores     Json?            @map("confidence_scores")
  companyId            String?          @map("company_id")
  pipelineSteps        Json?            @map("pipeline_steps")
  completionTokens     Int?             @map("completion_tokens")
  gptModelUsed         String?          @map("gpt_model_used")
  gptPrompt            String?          @map("gpt_prompt")
  gptResponse          String?          @map("gpt_response")
  imageDetailMode      String?          @map("image_detail_mode")
  promptTokens         Int?             @map("prompt_tokens")
  totalTokens          Int?             @map("total_tokens")
  extractionVersion    String?          @map("extraction_version")
  stage1AiDetails      Json?            @map("stage_1_ai_details")
  stage1DurationMs     Int?             @map("stage_1_duration_ms")
  stage1Result         Json?            @map("stage_1_result")
  stage2AiDetails      Json?            @map("stage_2_ai_details")
  stage2ConfigSource   String?          @map("stage_2_config_source")
  stage2DurationMs     Int?             @map("stage_2_duration_ms")
  stage2Result         Json?            @map("stage_2_result")
  stage3AiDetails      Json?            @map("stage_3_ai_details")
  stage3ConfigScope    String?          @map("stage_3_config_scope")
  stage3DurationMs     Int?             @map("stage_3_duration_ms")
  stage3Result         Json?            @map("stage_3_result")
  referenceNumberMatch Json?            @map("reference_number_match")
