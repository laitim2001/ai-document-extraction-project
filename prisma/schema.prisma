  description       String?
  isEnabled         Boolean  @default(true) @map("is_enabled")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("performance_thresholds")
}

model AlertRule {
  id              String             @id @default(cuid())
  name            String
  description     String?
  isActive        Boolean            @default(true) @map("is_active")
  conditionType   AlertConditionType @map("condition_type")
  metric          String
  operator        AlertOperator
  threshold       Float
  duration        Int
  serviceName     String?            @map("service_name")
  endpoint        String?
  severity        AlertSeverity
  channels        Json
  recipients      Json
  cooldownMinutes Int                @default(15) @map("cooldown_minutes")
  cityId          String?            @map("city_id")
  createdById     String             @map("created_by_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  city            City?              @relation(fields: [cityId], references: [id])
  createdBy       User               @relation("AlertRuleCreator", fields: [createdById], references: [id])
  alerts          Alert[]            @relation("AlertRuleAlerts")

  @@index([isActive])
  @@index([conditionType])
  @@index([severity])
  @@index([cityId])
  @@index([createdById])
  @@map("alert_rules")
}

model Alert {
  id             String                  @id @default(cuid())
  ruleId         String                  @map("rule_id")
  status         AlertStatus             @default(FIRING)
  acknowledgedBy String?                 @map("acknowledged_by")
  acknowledgedAt DateTime?               @map("acknowledged_at")
  resolvedBy     String?                 @map("resolved_by")
  resolvedAt     DateTime?               @map("resolved_at")
  resolution     String?
  triggeredValue Float                   @map("triggered_value")
  triggeredAt    DateTime                @default(now()) @map("triggered_at")
  recoveredAt    DateTime?               @map("recovered_at")
  details        Json?
  metricData     Json?                   @map("metric_data")
  cityId         String?                 @map("city_id")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  notifications  AlertRuleNotification[] @relation("AlertNotifications")
  city           City?                   @relation(fields: [cityId], references: [id])
  rule           AlertRule               @relation("AlertRuleAlerts", fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([status])
  @@index([triggeredAt])
  @@index([cityId])
  @@index([ruleId, status])
  @@map("alerts")
}

model AlertRuleNotification {
  id           String              @id @default(cuid())
  alertId      String              @map("alert_id")
  channel      NotificationChannel
  recipient    String
  subject      String
  body         String
  status       NotificationStatus  @default(PENDING)
  errorMessage String?             @map("error_message")
  sentAt       DateTime?           @map("sent_at")
  createdAt    DateTime            @default(now()) @map("created_at")
  alert        Alert               @relation("AlertNotifications", fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId])
  @@index([status])
  @@index([channel])
  @@map("alert_rule_notifications")
}

model Backup {
  id            String          @id @default(cuid())
  name          String
  description   String?
  type          BackupType
  source        BackupSource
  trigger       BackupTrigger
  status        BackupStatus    @default(PENDING)
  progress      Int             @default(0)
  errorMessage  String?         @map("error_message")
  storagePath   String?         @map("storage_path")
  sizeBytes     BigInt?         @map("size_bytes")
  checksum      String?
  contents      Json?
  startedAt     DateTime?       @map("started_at")
  completedAt   DateTime?       @map("completed_at")
  expiresAt     DateTime?       @map("expires_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  createdBy     String?         @map("created_by")
  scheduleId    String?         @map("schedule_id")
  createdByUser User?           @relation("BackupCreator", fields: [createdBy], references: [id])
  schedule      BackupSchedule? @relation(fields: [scheduleId], references: [id])
  restores      RestoreRecord[]

  @@index([status, createdAt])
  @@index([type, source])
  @@index([expiresAt])
  @@index([scheduleId])
  @@map("backups")
}

model BackupSchedule {
  id             String       @id @default(cuid())
  name           String
  description    String?
  isEnabled      Boolean      @default(true) @map("is_enabled")
  backupType     BackupType   @map("backup_type")
  backupSource   BackupSource @map("backup_source")
  cronExpression String       @map("cron_expression")
  timezone       String       @default("Asia/Taipei")
  retentionDays  Int          @default(30) @map("retention_days")
  maxBackups     Int          @default(10) @map("max_backups")
  nextRunAt      DateTime?    @map("next_run_at")
  lastRunAt      DateTime?    @map("last_run_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  createdBy      String?      @map("created_by")
  createdByUser  User?        @relation("BackupScheduleCreator", fields: [createdBy], references: [id])
  backups        Backup[]

  @@index([isEnabled, nextRunAt])
  @@index([createdBy])
  @@map("backup_schedules")
}

model BackupConfig {
  id                      String   @id @default(cuid())
  key                     String   @unique
  storageConnectionString String?  @map("storage_connection_string")
  containerName           String   @default("backups") @map("container_name")
  databaseHost            String?  @map("database_host")
  databasePort            Int      @default(5432) @map("database_port")
  databaseName            String?  @map("database_name")
  compressionEnabled      Boolean  @default(true) @map("compression_enabled")
  encryptionEnabled       Boolean  @default(true) @map("encryption_enabled")
  encryptionKey           String?  @map("encryption_key")
  notifyOnSuccess         Boolean  @default(false) @map("notify_on_success")
  notifyOnFailure         Boolean  @default(true) @map("notify_on_failure")
  notificationEmails      String[] @default([]) @map("notification_emails")
  updatedAt               DateTime @updatedAt @map("updated_at")

  @@map("backup_configs")
}

model BackupStorageUsage {
  id             String    @id @default(cuid())
  recordedAt     DateTime  @default(now()) @map("recorded_at")
  totalSizeBytes BigInt    @map("total_size_bytes")
  backupCount    Int       @map("backup_count")
  oldestBackupAt DateTime? @map("oldest_backup_at")
  newestBackupAt DateTime? @map("newest_backup_at")
  quotaBytes     BigInt?   @map("quota_bytes")
  usagePercent   Float?    @map("usage_percent")

  @@index([recordedAt])
  @@map("backup_storage_usage")
}

model RestoreRecord {
  id                     String         @id @default(cuid())
  backupId               String         @map("backup_id")
  type                   RestoreType    @default(FULL) @map("type")
  scope                  RestoreScope[]
  status                 RestoreStatus  @default(PENDING)
  targetEnvironment      String?        @map("target_environment")
  selectedTables         String[]       @default([]) @map("selected_tables")
  selectedFiles          String[]       @default([]) @map("selected_files")
  progress               Int            @default(0)
  currentStep            String?        @map("current_step")
  estimatedTimeRemaining Int?           @map("estimated_time_remaining")
  preRestoreBackupId     String?        @map("pre_restore_backup_id")
  restoredRecords        Json?          @map("restored_records")
  restoredFiles          Int?           @map("restored_files")
  restoredConfigs        Int?           @map("restored_configs")
  validationPassed       Boolean?       @map("validation_passed")
  validationDetails      Json?          @map("validation_details")
  errorMessage           String?        @map("error_message")
  errorDetails           Json?          @map("error_details")
  startedAt              DateTime?      @map("started_at")
  completedAt            DateTime?      @map("completed_at")
  createdAt              DateTime       @default(now()) @map("created_at")
  createdBy              String         @map("created_by")
  confirmationText       String?        @map("confirmation_text")
  confirmedAt            DateTime?      @map("confirmed_at")
  drill                  RestoreDrill?
  logs                   RestoreLog[]
  backup                 Backup         @relation(fields: [backupId], references: [id], onDelete: Cascade)
  createdByUser          User           @relation("RestoreRecordCreator", fields: [createdBy], references: [id])

  @@index([backupId])
  @@index([status, createdAt])
  @@index([createdBy])
  @@index([type])
  @@map("restore_records")
}

model RestoreDrill {
  id                String        @id @default(cuid())
  restoreRecordId   String        @unique @map("restore_record_id")
  drillEnvironment  String        @map("drill_environment")
  drillDatabaseName String?       @map("drill_database_name")
  drillStoragePath  String?       @map("drill_storage_path")
  drillStatus       String?       @map("drill_status")
  drillReport       Json?         @map("drill_report")
  cleanedUp         Boolean       @default(false) @map("cleaned_up")
  cleanedUpAt       DateTime?     @map("cleaned_up_at")
  createdAt         DateTime      @default(now()) @map("created_at")
  restoreRecord     RestoreRecord @relation(fields: [restoreRecordId], references: [id], onDelete: Cascade)

  @@index([drillStatus])
  @@map("restore_drills")
}

model RestoreLog {
  id              String        @id @default(cuid())
  restoreRecordId String        @map("restore_record_id")
  timestamp       DateTime      @default(now())
  level           String
  step            String
  message         String
  details         Json?
  restoreRecord   RestoreRecord @relation(fields: [restoreRecordId], references: [id], onDelete: Cascade)

  @@index([restoreRecordId, timestamp])
  @@index([level])
  @@map("restore_logs")
}

model SystemLog {
  id            String    @id @default(cuid())
  level         LogLevel  @default(INFO)
  source        LogSource @default(SYSTEM)
  message       String
  details       Json?
  correlationId String?   @map("correlation_id")
  requestId     String?   @map("request_id")
  sessionId     String?   @map("session_id")
  className     String?   @map("class_name")
  methodName    String?   @map("method_name")
  lineNumber    Int?      @map("line_number")
  errorCode     String?   @map("error_code")
  errorStack    String?   @map("error_stack")
  duration      Int?
  memoryUsage   Float?    @map("memory_usage")
  userId        String?   @map("user_id")
  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent")
  endpoint      String?
  timestamp     DateTime  @default(now())
  user          User?     @relation("SystemLogUser", fields: [userId], references: [id])

  @@index([level, timestamp])
  @@index([source, timestamp])
  @@index([correlationId])
  @@index([userId, timestamp])
  @@index([errorCode, timestamp])
  @@index([timestamp])
  @@map("system_logs")
}

model LogRetentionPolicy {
  id             String    @id @default(cuid())
  level          LogLevel  @unique
  retentionDays  Int       @map("retention_days")
  archiveEnabled Boolean   @default(false) @map("archive_enabled")
  autoCleanup    Boolean   @default(true) @map("auto_cleanup")
  lastCleanupAt  DateTime? @map("last_cleanup_at")
  recordsCleaned Int       @default(0) @map("records_cleaned")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("log_retention_policies")
}

model LogExport {
  id            String          @id @default(cuid())
  format        LogExportFormat @default(CSV)
  status        LogExportStatus @default(PENDING)
  levels        LogLevel[]
  sources       LogSource[]
  startDate     DateTime        @map("start_date")
  endDate       DateTime        @map("end_date")
  searchQuery   String?         @map("search_query")
  filePath      String?         @map("file_path")
  fileSize      BigInt?         @map("file_size")
  recordCount   Int?            @map("record_count")
  errorMessage  String?         @map("error_message")
  expiresAt     DateTime?       @map("expires_at")
  createdAt     DateTime        @default(now()) @map("created_at")
  completedAt   DateTime?       @map("completed_at")
  createdBy     String          @map("created_by")
  createdByUser User            @relation("LogExportCreator", fields: [createdBy], references: [id])

  @@index([status, createdAt])
  @@index([createdBy])
  @@index([expiresAt])
  @@map("log_exports")
}

/// 歷史數據批量處理任務
model HistoricalBatch {
  id                          String                 @id @default(uuid())
  name                        String
  description                 String?
  status                      HistoricalBatchStatus  @default(PENDING)
  totalFiles                  Int                    @default(0) @map("total_files")
  processedFiles              Int                    @default(0) @map("processed_files")
  failedFiles                 Int                    @default(0) @map("failed_files")
  errorMessage                String?                @map("error_message")
  createdAt                   DateTime               @default(now()) @map("created_at")
  updatedAt                   DateTime               @updatedAt @map("updated_at")
  startedAt                   DateTime?              @map("started_at")
  completedAt                 DateTime?              @map("completed_at")
  createdBy                   String                 @map("created_by")
  pausedAt                    DateTime?              @map("paused_at")
  currentFileId               String?                @map("current_file_id")
  skippedFiles                Int                    @default(0) @map("skipped_files")
  totalCost                   Float                  @default(0) @map("total_cost")
  newCompaniesCount           Int                    @default(0) @map("new_companies_count")
  extractedTermsCount         Int                    @default(0) @map("extracted_terms_count")
  enableCompanyIdentification Boolean                @default(true) @map("enable_company_identification")
  fuzzyMatchThreshold         Float                  @default(0.9) @map("fuzzy_match_threshold")
  autoMergeSimilar            Boolean                @default(false) @map("auto_merge_similar")
  companiesIdentified         Int                    @default(0) @map("companies_identified")
  enableTermAggregation       Boolean                @default(true) @map("enable_term_aggregation")
  termSimilarityThreshold     Float                  @default(0.85) @map("term_similarity_threshold")
  autoClassifyTerms           Boolean                @default(false) @map("auto_classify_terms")
  aggregationStartedAt        DateTime?              @map("aggregation_started_at")
  aggregationCompletedAt      DateTime?              @map("aggregation_completed_at")
  enableIssuerIdentification  Boolean                @default(true) @map("enable_issuer_identification")
  issuerConfidenceThreshold   Float                  @default(0.7) @map("issuer_confidence_threshold")
  autoCreateIssuerCompany     Boolean                @default(true) @map("auto_create_issuer_company")
  issuerFuzzyThreshold        Float                  @default(0.9) @map("issuer_fuzzy_threshold")
  issuersIdentified           Int                    @default(0) @map("issuers_identified")
  enableFormatIdentification  Boolean                @default(true) @map("enable_format_identification")
  formatConfidenceThreshold   Float                  @default(0.7) @map("format_confidence_threshold")
  autoCreateFormat            Boolean                @default(true) @map("auto_create_format")
  formatsIdentified           Int                    @default(0) @map("formats_identified")
  creator                     User                   @relation("HistoricalBatchCreator", fields: [createdBy], references: [id])
  files                       HistoricalFile[]
  termAggregationResult       TermAggregationResult?

  @@index([status])
  @@index([createdBy])
  @@index([createdAt])
  @@map("historical_batches")
}

/// 歷史文件記錄
model HistoricalFile {
  id                         String                      @id @default(uuid())
  batchId                    String                      @map("batch_id")
  fileName                   String                      @map("file_name")
  originalName               String                      @map("original_name")
  fileSize                   Int                         @map("file_size")
  mimeType                   String                      @map("mime_type")
  detectedType               DetectedFileType?           @map("detected_type")
  storagePath                String                      @map("storage_path")
  status                     HistoricalFileStatus        @default(PENDING)
  errorMessage               String?                     @map("error_message")
  metadata                   Json?
  createdAt                  DateTime                    @default(now()) @map("created_at")
  updatedAt                  DateTime                    @updatedAt @map("updated_at")
  detectedAt                 DateTime?                   @map("detected_at")
  processedAt                DateTime?                   @map("processed_at")
  processingMethod           ProcessingMethod?           @map("processing_method")
  processingStartAt          DateTime?                   @map("processing_start_at")
  processingEndAt            DateTime?                   @map("processing_end_at")
  actualCost                 Float?                      @map("actual_cost")
  extractionResult           Json?                       @map("extraction_result")
  identifiedCompanyId        String?                     @map("identified_company_id")
  companyMatchType           String?                     @map("company_match_type")
  companyMatchScore          Float?                      @map("company_match_score")
  documentIssuerId           String?                     @map("document_issuer_id")
  issuerIdentificationMethod IssuerIdentificationMethod? @map("issuer_identification_method")
  issuerConfidence           Float?                      @map("issuer_confidence")
  documentFormatId           String?                     @map("document_format_id")
  formatConfidence           Float?                      @map("format_confidence")
  transactionParties         FileTransactionParty[]
  batch                      HistoricalBatch             @relation(fields: [batchId], references: [id], onDelete: Cascade)
  documentFormat             DocumentFormat?             @relation(fields: [documentFormatId], references: [id])
  documentIssuer             Company?                    @relation("FileDocumentIssuer", fields: [documentIssuerId], references: [id])
  identifiedCompany          Company?                    @relation("FileIdentifiedCompany", fields: [identifiedCompanyId], references: [id])

  @@index([batchId])
  @@index([status])
  @@index([detectedType])
  @@index([processingMethod])
  @@index([identifiedCompanyId])
  @@index([documentIssuerId])
  @@index([documentFormatId])
  @@map("historical_files")
}

/// Story 0.7: 批量處理術語聚合結果
/// 儲存每個批次的術語聚合統計和詳細結果
model TermAggregationResult {
  id                   String          @id @default(uuid())
  batchId              String          @unique @map("batch_id")
  totalUniqueTerms     Int             @map("total_unique_terms")
  totalOccurrences     Int             @map("total_occurrences")
  universalTermsCount  Int             @map("universal_terms_count")
  companySpecificCount Int             @map("company_specific_count")
  classifiedTermsCount Int             @default(0) @map("classified_terms_count")
  resultData           Json            @map("result_data")
  aggregatedAt         DateTime        @default(now()) @map("aggregated_at")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  batch                HistoricalBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([aggregatedAt])
  @@map("term_aggregation_results")
}

/// 交易對象關聯表 - Story 0.8
/// 記錄文件與公司之間的交易關係（多對多）
model FileTransactionParty {
  id        String               @id @default(uuid())
  fileId    String               @map("file_id")
  companyId String               @map("company_id")
  role      TransactionPartyRole @map("role")
  createdAt DateTime             @default(now()) @map("created_at")
  company   Company              @relation(fields: [companyId], references: [id])
  file      HistoricalFile       @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, companyId, role])
  @@index([fileId])
  @@index([companyId])
  @@index([role])
  @@map("file_transaction_parties")
}

/// 文件格式模板 - Story 0.9
/// 每個公司的每種文件格式只有一個記錄
/// 建立三層結構：公司 → 文件格式 → 術語
model DocumentFormat {
  id                    String                 @id @default(cuid())
  companyId             String                 @map("company_id")
  documentType          DocumentType           @map("document_type")
  documentSubtype       DocumentSubtype        @map("document_subtype")
  name                  String?
  features              Json?                  @map("features")
  identificationRules   Json?                  @map("identification_rules")
  commonTerms           String[]               @map("common_terms")
  fileCount             Int                    @default(0) @map("file_count")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  defaultTemplateId     String?                @map("default_template_id")
  company               Company                @relation(fields: [companyId], references: [id])
  defaultTemplate       DataTemplate?          @relation("FormatDefaultTemplate", fields: [defaultTemplateId], references: [id])
  fieldMappingConfigs   FieldMappingConfig[]
  files                 HistoricalFile[]
  promptConfigs         PromptConfig[]
  templateFieldMappings TemplateFieldMapping[]

  @@unique([companyId, documentType, documentSubtype])
  @@index([companyId])
  @@index([documentType])
  @@map("document_formats")
}

/// Bulk operation tracking for undo functionality
/// Records batch operations on mapping rules for reversibility
model BulkOperation {
  id            String    @id @default(uuid())
  operationType String    @map("operation_type")
  affectedRules Json      @map("affected_rules")
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  createdBy     String    @map("created_by")
  isUndone      Boolean   @default(false) @map("is_undone")
  undoneAt      DateTime? @map("undone_at")
  undoneBy      String?   @map("undone_by")

  @@index([operationType])
  @@index([createdAt])
  @@index([isUndone])
  @@map("bulk_operations")
}

/// Field Mapping Configuration
/// Stores configuration sets for different scopes (Global/Company/Format)
/// Supports hierarchy override: GLOBAL → COMPANY → FORMAT
model FieldMappingConfig {
  id               String             @id @default(cuid())
  scope            FieldMappingScope  @default(GLOBAL)
  companyId        String?            @map("company_id")
  documentFormatId String?            @map("document_format_id")
  name             String             @db.VarChar(100)
  description      String?
  isActive         Boolean            @default(true) @map("is_active")
  version          Int                @default(1)
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  createdBy        String?            @map("created_by")
  dataTemplateId   String?            @map("data_template_id")
  company          Company?           @relation(fields: [companyId], references: [id])
  dataTemplate     DataTemplate?      @relation(fields: [dataTemplateId], references: [id])
  documentFormat   DocumentFormat?    @relation(fields: [documentFormatId], references: [id])
  rules            FieldMappingRule[]

  @@unique([scope, companyId, documentFormatId])
  @@index([companyId])
  @@index([documentFormatId])
  @@index([scope])
  @@index([isActive])
  @@index([dataTemplateId])
  @@map("field_mapping_configs")
}

/// Field Mapping Rule
/// Individual mapping rules within a configuration
/// Defines how source fields map to target fields with transformation
model FieldMappingRule {
  id              String             @id @default(cuid())
  configId        String             @map("config_id")
  sourceFields    Json               @map("source_fields")
  targetField     String             @map("target_field") @db.VarChar(100)
  transformType   FieldTransformType @default(DIRECT) @map("transform_type")
  transformParams Json?              @map("transform_params")
  priority        Int                @default(0)
  isActive        Boolean            @default(true) @map("is_active")
  description     String?            @db.VarChar(500)
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  config          FieldMappingConfig @relation(fields: [configId], references: [id], onDelete: Cascade)

  @@index([configId])
  @@index([targetField])
  @@index([priority])
  @@index([isActive])
  @@map("field_mapping_rules")
}

/// Prompt Configuration Model
/// Stores AI prompt templates with hierarchical scope support
/// Supports: GLOBAL → COMPANY → FORMAT configuration override
model PromptConfig {
  id                 String          @id @default(cuid())
  promptType         PromptType      @map("prompt_type")
  scope              PromptScope     @default(GLOBAL)
  name               String          @db.VarChar(100)
  description        String?
  companyId          String?         @map("company_id")
  documentFormatId   String?         @map("document_format_id")
  systemPrompt       String          @map("system_prompt")
  userPromptTemplate String          @map("user_prompt_template")
  mergeStrategy      MergeStrategy   @default(OVERRIDE) @map("merge_strategy")
  variables          Json?           @default("[]")
  isActive           Boolean         @default(true) @map("is_active")
  version            Int             @default(1)
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  createdBy          String?         @map("created_by")
  updatedBy          String?         @map("updated_by")
  company            Company?        @relation(fields: [companyId], references: [id])
  documentFormat     DocumentFormat? @relation(fields: [documentFormatId], references: [id])

  @@unique([promptType, scope, companyId, documentFormatId], name: "unique_prompt_config")
  @@index([promptType])
  @@index([scope])
  @@index([companyId])
  @@index([documentFormatId])
  @@index([isActive])
  @@map("prompt_configs")
}

/// Prompt Variable Definition Model
/// Stores reusable variable definitions for prompt templates
/// Variables can be referenced in prompts using {{variableName}} syntax
model PromptVariable {
  id           String   @id @default(cuid())
  name         String   @unique @db.VarChar(50)
  displayName  String   @map("display_name") @db.VarChar(100)
  description  String?
  variableType String   @map("variable_type") @db.VarChar(20)
  defaultValue String?  @map("default_value")
  dataSource   String?  @map("data_source") @db.VarChar(100)
  isRequired   Boolean  @default(false) @map("is_required")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("prompt_variables")
}

/// Data Template
/// Defines target field structure for data export/import
/// Supports ERP import formats, report formats, etc.
model DataTemplate {
  id                    String                 @id @default(cuid())
  name                  String                 @db.VarChar(200)
  description           String?
  scope                 DataTemplateScope      @default(GLOBAL)
  companyId             String?                @map("company_id")
  fields                Json
  isActive              Boolean                @default(true) @map("is_active")
  isSystem              Boolean                @default(false) @map("is_system")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  createdBy             String?                @map("created_by")
  companiesAsDefault    Company[]              @relation("CompanyDefaultTemplate")
  company               Company?               @relation(fields: [companyId], references: [id])
  formatsAsDefault      DocumentFormat[]       @relation("FormatDefaultTemplate")
  fieldMappingConfigs   FieldMappingConfig[]
  templateFieldMappings TemplateFieldMapping[]
  templateInstances     TemplateInstance[]

  @@index([scope])
  @@index([companyId])
  @@index([isActive])
  @@index([isSystem])
  @@map("data_templates")
}

/// *
///  * 模版欄位映射配置
///  * 定義標準欄位到數據模版欄位的映射規則
///  *
///  * @description
///  *   - 支援三層優先級：FORMAT > COMPANY > GLOBAL
///  *   - 每個 DataTemplate 可有多個映射配置
///  *   - 映射規則支援直接映射、公式計算、查表映射
///  *
///  * @since Epic 19 - Story 19.1
model TemplateFieldMapping {
  id               String                    @id @default(cuid())
  dataTemplateId   String                    @map("data_template_id")
  scope            TemplateFieldMappingScope @default(GLOBAL)
  companyId        String?                   @map("company_id")
  documentFormatId String?                   @map("document_format_id")
  name             String                    @db.VarChar(200)
  description      String?
  /// *
  ///    * 映射規則陣列 (JSON)
  ///    * @type TemplateFieldMappingRule[]
  ///    * 結構: {
  ///    *   id: string,
  ///    *   sourceField: string,     // 標準欄位名
  ///    *   targetField: string,     // 模版欄位名
  ///    *   transformType: 'DIRECT' | 'FORMULA' | 'LOOKUP',
  ///    *   transformParams?: { formula?: string, lookupTable?: object, defaultValue?: any },
  ///    *   isRequired: boolean,
  ///    *   order: number,
  ///    *   description?: string
  ///    * }[]
  mappings         Json                      @default("[]")
  priority         Int                       @default(0)
  isActive         Boolean                   @default(true) @map("is_active")
  createdAt        DateTime                  @default(now()) @map("created_at")
  updatedAt        DateTime                  @updatedAt @map("updated_at")
  createdBy        String?                   @map("created_by")
  company          Company?                  @relation(fields: [companyId], references: [id])
  dataTemplate     DataTemplate              @relation(fields: [dataTemplateId], references: [id], onDelete: Cascade)
  documentFormat   DocumentFormat?           @relation(fields: [documentFormatId], references: [id])

  @@unique([dataTemplateId, scope, companyId, documentFormatId], name: "unique_template_mapping")
  @@index([dataTemplateId])
  @@index([scope])
  @@index([companyId])
  @@index([documentFormatId])
  @@index([isActive])
  @@map("template_field_mappings")
}

/// *
///  * 模版實例模型
///  * @description
///  *   存儲填充後的模版數據，包含元數據和狀態
///  *   每個實例對應一個 DataTemplate，包含多個 TemplateInstanceRow
///  *
///  * @since Epic 19 - Story 19.2
///  *
///  * @example
///  *   DataTemplate: "海運費用報表"
///  *   TemplateInstance: "2026年1月海運費用"
///  *     - Row 1: { shipment_no: 'S001', shipping_cost: 500 }
///  *     - Row 2: { shipment_no: 'S002', shipping_cost: 450 }
model TemplateInstance {
  id               String                 @id @default(cuid())
  dataTemplateId   String                 @map("data_template_id")
  name             String                 @db.VarChar(200)
  description      String?
  status           TemplateInstanceStatus @default(DRAFT)
  rowCount         Int                    @default(0) @map("row_count")
  validRowCount    Int                    @default(0) @map("valid_row_count")
  errorRowCount    Int                    @default(0) @map("error_row_count")
  exportedAt       DateTime?              @map("exported_at")
  exportedBy       String?                @map("exported_by")
  exportFormat     String?                @map("export_format") @db.VarChar(20)
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  createdBy        String?                @map("created_by")
  matchedDocuments Document[]             @relation("TemplateInstanceDocuments")
  rows             TemplateInstanceRow[]
  dataTemplate     DataTemplate           @relation(fields: [dataTemplateId], references: [id])

  @@index([dataTemplateId])
  @@index([status])
  @@index([createdAt])
  @@map("template_instances")
}

/// *
///  * 模版實例行模型
///  * @description
///  *   存儲模版實例中的每一行數據
///  *   以 rowKey（如 shipment_no 或 invoice_no）為主鍵
///  *   支持多對一（多個文件合併為一行）
///  *
///  * @since Epic 19 - Story 19.2
model TemplateInstanceRow {
  id                 String                    @id @default(cuid())
  templateInstanceId String                    @map("template_instance_id")
  rowKey             String                    @map("row_key")
  rowIndex           Int                       @map("row_index")
  sourceDocumentIds  String[]                  @map("source_document_ids")
  fieldValues        Json                      @map("field_values")
  validationErrors   Json?                     @map("validation_errors")
  status             TemplateInstanceRowStatus @default(PENDING)
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @updatedAt @map("updated_at")
  templateInstance   TemplateInstance          @relation(fields: [templateInstanceId], references: [id], onDelete: Cascade)

  @@unique([templateInstanceId, rowKey])
  @@index([templateInstanceId])
  @@index([status])
  @@map("template_instance_rows")
}

/**
 * 參考號碼主檔
 * 用於管理 Shipment/Delivery Number 等參考號碼
 * @since Epic 20 - Story 20.1
 */
model ReferenceNumber {
  id              String                  @id @default(cuid())

  // ================================
  // 識別資訊
  // ================================
  code            String                  @unique  // 唯一識別碼（導入導出用）
  number          String                           // 號碼值
  type            ReferenceNumberType     @default(SHIPMENT)
  status          ReferenceNumberStatus   @default(ACTIVE)

  // ================================
  // 分類資訊
  // ================================
  year            Int                              // 年份
  regionId        String                  @map("region_id")
  region          Region                  @relation(fields: [regionId], references: [id])

  // ================================
  // 描述資訊
  // ================================
  description     String?

  // ================================
  // 有效期
  // ================================
  validFrom       DateTime?               @map("valid_from")
  validUntil      DateTime?               @map("valid_until")

  // ================================
  // 使用追蹤
  // ================================
  matchCount      Int                     @default(0) @map("match_count")
  lastMatchedAt   DateTime?               @map("last_matched_at")

  // ================================
  // 狀態與審計
  // ================================
  isActive        Boolean                 @default(true) @map("is_active")
  createdById     String                  @map("created_by_id")
  createdAt       DateTime                @default(now()) @map("created_at")
  updatedAt       DateTime                @updatedAt @map("updated_at")

  // ================================
  // 約束與索引
  // ================================
  @@unique([number, type, year, regionId], name: "unique_reference_number")
  @@index([year])
  @@index([type])
  @@index([status])
  @@index([regionId])
  @@index([isActive])
  @@index([number])  // 用於搜尋
  @@map("reference_numbers")
}

